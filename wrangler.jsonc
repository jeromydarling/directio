{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "directio",
  "compatibility_date": "2025-04-04",
  "compatibility_flags": ["nodejs_compat"],
  "main": "./workers/app.ts",

  "observability": {
    "enabled": true
  },

  "triggers": {
    "crons": [
      "0 * * * *"
    ]
  },

  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "directio-dev",
      "database_id": "c0cf0619-a5f5-4ed4-ad7e-e1bfe7cb73db",
      "migrations_dir": "migrations"
    }
  ],

  "r2_buckets": [
    {
      "binding": "ASSETS",
      "bucket_name": "directio-dev-assets"
    },
    {
      "binding": "STATE_KB_BUCKET",
      "bucket_name": "directio-state-knowledge"
    }
  ],

  "kv_namespaces": [
    {
      "binding": "CACHE",
      "id": "032cdcf60cfa4dce999cdc372b5e2765"
    }
  ],

  "ai": {
    "binding": "AI"
  },

  "browser": {
    "binding": "BROWSER"
  },

  "workflows": [
    {
      "name": "directio-state-audit",
      "binding": "STATE_AUDIT",
      "class_name": "StateAuditWorkflow"
    }
  ],

  "ai_search": [
    {
      "binding": "STATE_KB",
      "instance_name": "directio-states"
    }
  ],

  "vars": {
    "APP_ENV": "development",
    "APP_URL": "http://localhost:5173",
    "BETTER_AUTH_SECRET": "set-via-dev-vars-or-secret",
    "STRIPE_SECRET_KEY": "set-in-keys-pass",
    "STRIPE_PUBLISHABLE_KEY": "set-in-keys-pass",
    "STRIPE_WEBHOOK_SECRET": "set-in-keys-pass",
    "MAPBOX_PUBLIC_TOKEN": "set-in-keys-pass",
    "PERPLEXITY_API_KEY": "set-in-keys-pass",
    "ELEVENLABS_API_KEY": "set-in-keys-pass",
    "ANTHROPIC_API_KEY": "set-in-keys-pass",
    "RESEND_API_KEY": "set-in-keys-pass",
    "RESEND_FROM": "directio <no-reply@directio.app>",
    "AI_GATEWAY_ACCOUNT_ID": "f84f7181c051be0040e972dcad48e697",
    "AI_GATEWAY_NAME": "directio-llm",
    "SAAS_ZONE_ID": "set-when-zone-is-chosen"
  }
}
